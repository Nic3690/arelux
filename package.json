{
	"name": "configuratore-admin",
	"version": "0.1.0",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build && svelte-check",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"types": "supabase gen types --local typescript > src/lib/dbschema.d.ts"
	},
	"devDependencies": {
		"@sveltejs/adapter-netlify": "^4.4.0",
		"@sveltejs/kit": "^2.15.0",
		"@sveltejs/vite-plugin-svelte": "^5.0.0",
		"@types/lodash": "^4.17.16",
		"@types/three": "^0.170.0",
		"autoprefixer": "^10.4.20",
		"eslint": "^9.7.0",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-svelte": "^2.36.0",
		"prettier": "^3.5.3",
		"prettier-plugin-svelte": "^3.2.6",
		"prettier-plugin-tailwindcss": "^0.6.5",
		"supabase": "^2.2.1",
		"svelte": "^4.2.10",
		"svelte-check": "^4.0.0",
		"tailwindcss": "^3.4.9",
		"typescript": "^5.0.0",
		"vite": "^6.0.0",
		"zod": "^3.24.1"
	},
	"dependencies": {
		"@supabase/supabase-js": "^2.47.2",
		"handlebars": "^4.7.8",
		"html2pdf.js": "^0.10.2",
		"lodash": "^4.17.21",
		"three": "^0.171.0"
	}
}